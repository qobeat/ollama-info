#!/usr/bin/env bash
set -Eeuo pipefail

BASE_URL="${BASE_URL:-${OLLAMA_URL:-http://127.0.0.1:11434}}"
SCRIPT_DIR="$(cd -- "$(dirname -- "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
COMMON_SCRIPT="$SCRIPT_DIR/ollama-common.sh"
[[ -r "$COMMON_SCRIPT" ]] || { echo "ERROR: missing readable $COMMON_SCRIPT" >&2; exit 2; }
# shellcheck source=/dev/null
source "$COMMON_SCRIPT"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<EOF_HELP
Usage: ollama-stop [--kill]

Default: stop ollama.service when managed by systemd.
--kill:  bypass systemd and terminate ollama serve/runner processes directly.
EOF_HELP
  exit 0
fi

if [[ "${1:-}" == "--kill" || "${KILL_ONLY:-0}" == "1" ]]; then
  echo "Stopping Ollama serve/runner processes directly"
  pkill -TERM -f "ollama runner" 2>/dev/null || true
  pkill -TERM -f "ollama serve" 2>/dev/null || true
  sleep 1
  pkill -KILL -f "ollama runner" 2>/dev/null || true
  pkill -KILL -f "ollama serve" 2>/dev/null || true
elif ollama_system_service_exists; then
  echo "Stopping system service: sudo systemctl stop ollama"
  if ! ollama_systemctl_privileged stop ollama.service; then
    echo "ERROR: sudo/systemctl stop ollama.service failed." >&2
    echo "Try manually: sudo systemctl stop ollama" >&2
    echo "Check:        systemctl status ollama --no-pager" >&2
    exit 3
  fi
elif ollama_user_service_exists; then
  echo "Stopping user service: systemctl --user stop ollama"
  if ! systemctl --user stop ollama; then
    echo "ERROR: systemctl --user stop ollama failed." >&2
    echo "Try manually: systemctl --user stop ollama" >&2
    echo "Check:        systemctl --user status ollama --no-pager" >&2
    exit 3
  fi
else
  echo "No ollama.service found; stopping direct processes"
  pkill -TERM -f "ollama runner" 2>/dev/null || true
  pkill -TERM -f "ollama serve" 2>/dev/null || true
fi

sleep 1
if ollama_api_ready "$BASE_URL" 2; then
  echo "WARN: Ollama API still responds at $BASE_URL"
else
  echo "Ollama API: not responding at $BASE_URL"
fi
