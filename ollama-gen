#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="0.5.0"

need_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "ERROR: missing command: $1" >&2; exit 2; }; }
die() { echo "ERROR: $*" >&2; exit 1; }
log_info() { echo "INFO: $*" >&2; }
log_warn() { echo "WARN: $*" >&2; }
run_cmd() { "$@"; }

usage() {
  cat <<'EOF_USAGE'
ollama-gen - query Ollama /api/generate

Usage:
  ollama-gen [options] "prompt text"
  echo "prompt text" | ollama-gen [options]

Options:
  -h, --help        Show help
  -d, --debug       Print curl command to STDERR
  -m, --model NAME  Model name (default: $OLLAMA_MODEL or gemma3:1b)
  --url URL         Ollama base URL (default: $OLLAMA_URL or http://localhost:11434)
  --gpu             Allow default GPU offload; without this, num_gpu=0 is forced
  --list            List local models
  --json            Output normalized JSON
  --raw             With --json, print upstream JSON exactly

Env:
  OLLAMA_URL, OLLAMA_MODEL, OLLAMA_KEEP_ALIVE, OLLAMA_TEMP, OLLAMA_STREAM, TIMEOUT_SEC
  OLLAMA_NUM_CTX, OLLAMA_NUM_BATCH, OLLAMA_NUM_PREDICT, OLLAMA_LOW_VRAM, OLLAMA_NUM_GPU
EOF_USAGE
}

MODEL="${OLLAMA_MODEL:-gemma3:1b}"
URL="${OLLAMA_URL:-http://localhost:11434}"
KEEP_ALIVE="${OLLAMA_KEEP_ALIVE:-30m}"
TEMP="${OLLAMA_TEMP:-0}"
STREAM="${OLLAMA_STREAM:-false}"
TIMEOUT_SEC="${TIMEOUT_SEC:-}"
DEBUG_FLAG=0
ALLOW_GPU=0
DO_LIST=0
OUT_JSON=0
RAW_JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -d|--debug) DEBUG_FLAG=1; shift ;;
    -m|--model) MODEL="${2:-}"; shift 2 ;;
    --url) URL="${2:-}"; shift 2 ;;
    --gpu) ALLOW_GPU=1; shift ;;
    --list) DO_LIST=1; shift ;;
    --json) OUT_JSON=1; shift ;;
    --raw) RAW_JSON=1; shift ;;
    *) break ;;
  esac
done

need_cmd curl
need_cmd jq

if [[ "$DO_LIST" == "1" ]]; then
  if command -v ollama >/dev/null 2>&1; then
    ollama list
  else
    log_warn "ollama CLI not found; falling back to /api/tags"
    curl -fsS "${URL}/api/tags" | jq .
  fi
  exit 0
fi

if [[ $# -gt 0 ]]; then
  PROMPT="$*"
elif [[ ! -t 0 ]]; then
  PROMPT="$(cat)"
else
  usage >&2
  exit 2
fi

[[ -n "$MODEL" ]] || die "Model is empty"
[[ -n "$URL" ]] || die "URL is empty"

jq_bool() { [[ "$1" == "true" ]] && echo true || echo false; }

options="$(jq -n '{}')"
if [[ "$TEMP" =~ ^-?[0-9]+([.][0-9]+)?$ ]]; then
  options="$(jq -n --argjson t "$TEMP" --argjson o "$options" '$o + {temperature: $t}')"
fi
if [[ "$ALLOW_GPU" == "0" ]]; then
  options="$(jq -n --argjson o "$options" '$o + {num_gpu: 0}')"
elif [[ -n "${OLLAMA_NUM_GPU:-}" && "${OLLAMA_NUM_GPU:-}" =~ ^[0-9]+$ ]]; then
  options="$(jq -n --argjson n "$OLLAMA_NUM_GPU" --argjson o "$options" '$o + {num_gpu: $n}')"
fi

add_num() {
  local var="$1" key="$2" val="${!1:-}"
  [[ -n "$val" && "$val" =~ ^-?[0-9]+$ ]] || return 0
  options="$(jq -n --argjson v "$val" --argjson o "$options" '$o + {("'"$key"'"): $v}')"
}
add_bool() {
  local var="$1" key="$2" val="${!1:-}"
  [[ "$val" == "true" || "$val" == "false" ]] || return 0
  options="$(jq -n --argjson o "$options" --argjson v "$(jq_bool "$val")" '$o + {("'"$key"'"): $v}')"
}
add_num OLLAMA_NUM_CTX num_ctx
add_num OLLAMA_NUM_BATCH num_batch
add_num OLLAMA_NUM_PREDICT num_predict
add_bool OLLAMA_LOW_VRAM low_vram

payload="$(jq -n --arg model "$MODEL" --arg prompt "$PROMPT" --arg keep "$KEEP_ALIVE" --argjson stream "$(jq_bool "$STREAM")" --argjson options "$options" '{model:$model,prompt:$prompt,stream:$stream,keep_alive:$keep,options:$options}')"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

curl_args=(-fsS -H 'Content-Type: application/json' -d "$payload" "${URL}/api/generate")
if [[ -n "$TIMEOUT_SEC" ]]; then curl_args=(--max-time "$TIMEOUT_SEC" "${curl_args[@]}"); fi
if [[ "$DEBUG_FLAG" == "1" || "${DEBUG:-0}" == "1" ]]; then log_info "curl ${curl_args[*]}"; fi

run_cmd curl "${curl_args[@]}" >"$tmp"

if [[ "$OUT_JSON" == "1" ]]; then
  if [[ "$RAW_JSON" == "1" ]]; then
    cat "$tmp"
  else
    jq '{
      model, created_at, response, thinking, done, done_reason,
      prompt_eval_count, eval_count,
      load_duration_s:        (if .load_duration then .load_duration/1000000000 else null end),
      prompt_eval_duration_s: (if .prompt_eval_duration then .prompt_eval_duration/1000000000 else null end),
      eval_duration_s:        (if .eval_duration then .eval_duration/1000000000 else null end),
      total_duration_s:       (if .total_duration then .total_duration/1000000000 else null end),
      gen_tps:                (if .eval_duration and .eval_duration > 0 then (.eval_count / (.eval_duration/1000000000)) else null end)
    }' "$tmp"
  fi
else
  jq -r '.response // empty' "$tmp"
fi
