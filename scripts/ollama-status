#!/usr/bin/env bash
set -Eeuo pipefail

BASE_URL="${BASE_URL:-${OLLAMA_URL:-http://127.0.0.1:11434}}"
MODEL_DIR="${OLLAMA_MODELS:-$HOME/.ollama/models}"
LOG_FILE="${OLLAMA_SERVE_LOG:-$HOME/log/ollama-serve.log}"
SCRIPT_DIR="$(cd -- "$(dirname -- "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
COMMON_SCRIPT="$SCRIPT_DIR/ollama-common.sh"
[[ -r "$COMMON_SCRIPT" ]] || { echo "ERROR: missing readable $COMMON_SCRIPT" >&2; exit 2; }
# shellcheck source=/dev/null
source "$COMMON_SCRIPT"

MODE="brief"
case "${1:-}" in
  -h|--help)
    cat <<EOF_HELP
Usage: ollama-status [--brief|--models|--full]

--brief  Show service/API/GPU readiness only. Default. Alias: --short.
--models List local models with benchmark command lines.
--full   Add CLI version, downloaded/loaded models, disk usage, processes, and recent logs.
EOF_HELP
    exit 0
    ;;
  --brief|--short|-s|"") MODE="brief" ;;
  --models|-m) MODE="models" ;;
  --full|-f) MODE="full" ;;
  *) echo "ERROR: unknown option: $1" >&2; echo "Use: ollama-status --help" >&2; exit 2 ;;
esac

if [[ "$MODE" == "models" ]]; then
  if ollama_api_ready "$BASE_URL" 3; then
    ollama_print_available_model_commands "$BASE_URL" "ollama-test-and-monitor-RTX3090.sh" 5
  else
    ollama_print_start_hint "$BASE_URL"
    exit 3
  fi
  exit 0
fi

ollama_status_short_common "$BASE_URL" 3

if [[ "$MODE" != "full" ]]; then
  exit 0
fi

echo
echo "=== Ollama CLI ==="
if command -v ollama >/dev/null 2>&1; then
  command -v ollama
  ollama --version 2>/dev/null || true
else
  echo "ollama CLI not found"
fi

echo
echo "=== Downloaded models ==="
if ollama_api_ready "$BASE_URL" 3; then
  ollama list 2>/dev/null || ollama_tags_json "$BASE_URL" 5 | jq .
else
  echo "Cannot list models because API is not reachable."
  ollama_print_start_hint "$BASE_URL"
fi

echo
echo "=== Loaded models / runners ==="
if ollama_api_ready "$BASE_URL" 3; then
  ollama ps 2>/dev/null || curl -fsS "$BASE_URL/api/ps" | jq .
else
  echo "No server response from /api/ps."
fi

echo
echo "=== Model disk usage ==="
echo "model_dir: $MODEL_DIR"
if [[ -d "$MODEL_DIR" ]]; then
  du -sh "$MODEL_DIR" 2>/dev/null || true
  echo
  echo "Largest blobs:"
  if [[ -d "$MODEL_DIR/blobs" ]]; then
    find "$MODEL_DIR/blobs" -type f -printf '%s %p\n' 2>/dev/null \
      | sort -nr \
      | head -10 \
      | awk '{size=$1; $1=""; printf "%.2f GiB %s\n", size/1024/1024/1024, $0}'
  else
    echo "No blobs directory."
  fi
else
  echo "Model directory does not exist."
fi

echo
echo "=== GPU quick status ==="
if command -v nvidia-smi >/dev/null 2>&1; then
  nvidia-smi --query-gpu=timestamp,index,name,driver_version,temperature.gpu,power.draw,power.limit,memory.used,memory.total,utilization.gpu,utilization.memory,clocks.gr,clocks.sm,clocks.mem,pcie.link.gen.current,pcie.link.width.current,pcie.link.gen.max,pcie.link.width.max,pstate,fan.speed --format=csv 2>/dev/null || nvidia-smi
  echo
  echo "GPU processes:"
  nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv 2>/dev/null || true
else
  echo "nvidia-smi not found."
fi

echo
echo "=== Ollama processes ==="
pgrep -af 'ollama( serve| runner| pull|$)|llama-server|ollama_llama_server' || true

echo
echo "=== Recent Ollama log lines ==="
if ollama_system_service_exists && command -v journalctl >/dev/null 2>&1; then
  journalctl -u ollama -n 80 --no-pager 2>/dev/null || true
elif ollama_user_service_exists && command -v journalctl >/dev/null 2>&1; then
  journalctl --user -u ollama -n 80 --no-pager 2>/dev/null || true
elif [[ -f "$LOG_FILE" ]]; then
  grep -Ei "Listening|CUDA|RTX|offload|offloaded|loaded CUDA|error|warn|failure|memory|runner" "$LOG_FILE" | tail -80 || true
else
  echo "No known log source found."
fi
